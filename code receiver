// ================================================================
// NETZWERK SETUP
// ================================================================
void setupNetwork() {
  // AP für ESP-NOW Empfang auf festem Kanal
  WiFi.mode(WIFI_AP_STA);
  WiFi.softAP(AP_SSID, AP_PASS, ESPNOW_CHANNEL);
  Serial.print("AP IP: ");
  Serial.println(WiFi.softAPIP());

  // Mit Heim-WLAN verbinden (für Telegram)
  Serial.print("Verbinde mit WLAN: ");
  Serial.println(WIFI_SSID);
  WiFi.begin(WIFI_SSID, WIFI_PASS);

  int tries = 0;
  while (WiFi.status() != WL_CONNECTED && tries < 20) {
    delay(500);
    Serial.print(".");
    tries++;
  }

  if (WiFi.status() == WL_CONNECTED) {
    Serial.println("\nWLAN verbunden! IP: " + WiFi.localIP().toString());
  } else {
    Serial.println("\nWLAN nicht erreichbar – Telegram deaktiviert.");
  }

  Serial.print("Empfaenger MAC: ");
  Serial.println(WiFi.macAddress());

  // TLS ohne Zertifikatsprüfung (reicht für Schul-/Hobbyprojekte)
  secureClient.setInsecure();
}

// ================================================================
// TELEGRAM – Nachricht senden
// ================================================================
void sendTelegram(const String& text) {
  if (WiFi.status() != WL_CONNECTED) return;
  bot.sendMessage(CHAT_ID, text, "");
}

// ================================================================
// TELEGRAM – Status-Nachricht zusammenbauen
// ================================================================
String buildStatusMessage() {
  if (!hasCurrentPacket) return "⚠️ Noch keine Sensordaten empfangen.";

  String msg = "📡 *ESP32 Sensorstatus*\n";
  msg += "━━━━━━━━━━━━━━━━━━\n";
  msg += currentPacket.sleeping ? "💤 Modus: *Sleep*\n" : "✅ Modus: *Awake*\n";
  msg += "⏱ Verbleibend: " + String(currentPacket.secondsLeft) + " s\n\n";

  msg += "🌡 Temperatur:  " + String(currentPacket.temperatureC, 1) + " °C\n";
  msg += "💧 Luftfeuchte: " + String(currentPacket.humidityPct, 1) + " %\n";
  msg += "📏 Distanz:     " + String(currentPacket.distanceCm, 1) + " cm\n";
  msg += "💡 Licht:       ";
  msg += currentPacket.dark ? "Dunkel 🌑\n" : "Hell ☀️\n";
  msg += "🏃 Bewegung:    ";
  msg += currentPacket.motion ? "Ja ✅\n" : "Nein ❌\n";
  msg += "📐 Neigung:     ";
  msg += currentPacket.tilt ? "Ja ✅\n" : "Nein ❌\n";

  unsigned long ageSec = (millis() - lastReceiveMs) / 1000;
  msg += "\n📦 Paket #" + String(currentPacket.seq);
  msg += " | vor " + String(ageSec) + " s";

  return msg;
}

// ================================================================
// TELEGRAM – eingehende Befehle verarbeiten
// ================================================================
void handleTelegramCommands() {
  if (WiFi.status() != WL_CONNECTED) return;

  unsigned long now = millis();
  if (now - lastTelegramPollMs < TELEGRAM_POLL_MS) return;
  lastTelegramPollMs = now;

  int numMessages = bot.getUpdates(bot.last_message_received + 1);

  for (int i = 0; i < numMessages; i++) {
    String text    = bot.messages[i].text;
    String chat_id = bot.messages[i].chat_id;

    Serial.println("Telegram Nachricht: " + text);

    // Nur auf die eigene Chat-ID reagieren
    if (chat_id != String(CHAT_ID)) {
      bot.sendMessage(chat_id, "⛔ Nicht autorisiert.", "");
      continue;
    }

    // ---- Befehle ----
    if (text == "/start" || text == "/help") {
      String help = "🤖 *ESP32 Telegram Bot*\n\n";
      help += "Verfügbare Befehle:\n";
      help += "/status  – Aktuelle Sensordaten\n";
      help += "/alerts  – Motion-Alerts an/aus\n";
      help += "/auto    – Auto-Status (5 min) an/aus\n";
      help += "/hilfe   – Diese Hilfe\n";
      bot.sendMessage(CHAT_ID, help, "Markdown");
    }

    else if (text == "/status") {
      bot.sendMessage(CHAT_ID, buildStatusMessage(), "Markdown");
    }

    else if (text == "/alerts") {
      alertsEnabled = !alertsEnabled;
      String reply = alertsEnabled
        ? "✅ Motion-Alerts *aktiviert*."
        : "🔕 Motion-Alerts *deaktiviert*.";
      bot.sendMessage(CHAT_ID, reply, "Markdown");
    }

    else if (text == "/auto") {
      statusEnabled = !statusEnabled;
      String reply = statusEnabled
        ? "✅ Automatischer Status alle 5 min *aktiviert*."
        : "🔕 Automatischer Status *deaktiviert*.";
      bot.sendMessage(CHAT_ID, reply, "Markdown");
    }

    else if (text == "/hilfe") {
      bot.sendMessage(CHAT_ID, "ℹ️ Tippe /help für alle Befehle.", "");
    }

    else {
      bot.sendMessage(CHAT_ID, "❓ Unbekannter Befehl. Tippe /help.", "");
    }
  }
}

// ================================================================
// TELEGRAM – automatische Alerts & Periodik-Status
// ================================================================
void handleTelegramAlerts() {
  if (!hasCurrentPacket) return;
  unsigned long now = millis();

  // Motion-Alert: nur bei neuer Bewegungserkennung + Cooldown
  if (alertsEnabled) {
    bool currentMotion = (bool)currentPacket.motion;
    if (currentMotion && !lastMotionState &&
        now - lastMotionAlertMs > MOTION_COOLDOWN_MS) {
      String alert = "🚨 *Bewegung erkannt!*\n";
      alert += "📏 Distanz: " + String(currentPacket.distanceCm, 1) + " cm\n";
      alert += "🌡 Temp: " + String(currentPacket.temperatureC, 1) + " °C\n";
      alert += "📐 Neigung: " + String(currentPacket.tilt ? "Ja" : "Nein");
      sendTelegram(alert);
      lastMotionAlertMs = now;
    }
    lastMotionState = currentMotion;
  }

  // Automatischer Periodik-Status
  if (statusEnabled && STATUS_INTERVAL_MS > 0 &&
      now - lastStatusSentMs > STATUS_INTERVAL_MS) {
    sendTelegram(buildStatusMessage());
    lastStatusSentMs = now;
  }
}

// ================================================================
// HISTORY HELPERS (unverändert)
// ================================================================
void resetBucket(HistoryBucket &b, uint32_t slot) {
  b.valid = true; b.slot = slot; b.count = 0;
  b.distanceCm = 0; b.temperatureC = 0;
  b.humidityPct = 0; b.lightRaw = 0;
  b.motionCount = 0; b.tiltCount = 0; b.darkCount = 0;
}

void addToBucket(HistoryBucket &b, SensorPacket &p) {
  b.count++;
  b.distanceCm    += (p.distanceCm    - b.distanceCm)    / b.count;
  b.temperatureC  += (p.temperatureC  - b.temperatureC)  / b.count;
  b.humidityPct   += (p.humidityPct   - b.humidityPct)   / b.count;
  b.lightRaw      += ((float)p.lightRaw - b.lightRaw)    / b.count;
  if (p.motion) b.motionCount++;
  if (p.tilt)   b.tiltCount++;
  if (p.dark)   b.darkCount++;
}

void addToHistoryArray(HistoryBucket buckets[], int count, unsigned long ms, SensorPacket &p) {
  uint32_t slot  = millis() / ms;
  int      index = slot % count;
  if (!buckets[index].valid || buckets[index].slot != slot)
    resetBucket(buckets[index], slot);
  addToBucket(buckets[index], p);
}

void addToHistory(SensorPacket &p) {
  addToHistoryArray(hourHistory, HOUR_BUCKETS, HOUR_BUCKET_MS, p);
  addToHistoryArray(weekHistory, WEEK_BUCKETS, WEEK_BUCKET_MS, p);
}

// ================================================================
// ESP-NOW EMPFANG
// ================================================================
void onDataRecv(const esp_now_recv_info_t *info, const uint8_t *data, int len) {
  if (len != sizeof(SensorPacket)) return;
  SensorPacket pkt;
  memcpy(&pkt, data, sizeof(pkt));
  if (pkt.magic != PACKET_MAGIC || pkt.version != PACKET_VERSION) return;

  portENTER_CRITICAL(&packetMux);
  pendingPacket    = pkt;
  hasPendingPacket = true;
  portEXIT_CRITICAL(&packetMux);
}

void processPendingPacket() {
  if (!hasPendingPacket) return;

  SensorPacket pkt;
  portENTER_CRITICAL(&packetMux);
  pkt              = pendingPacket;
  hasPendingPacket = false;
  portEXIT_CRITICAL(&packetMux);

  currentPacket    = pkt;
  hasCurrentPacket = true;
  lastReceiveMs    = millis();

  if (pkt.historySample) addToHistory(pkt);

  Serial.printf("Pkt #%u %s Rest:%ds T:%.1f D:%.1f\n",
    pkt.seq, pkt.sleeping ? "Sleep" : "Awake",
    pkt.secondsLeft, pkt.temperatureC, pkt.distanceCm);
}

// ================================================================
// WEBSERVER API (unverändert)
// ================================================================
String boolText(bool v) { return v ? "true" : "false"; }

void handleRoot() { server.send_P(200, "text/html", INDEX_HTML); }

void handleCurrent() {
  if (!hasCurrentPacket) {
    server.send(200, "application/json", "{\"online\":false}");
    return;
  }
  String json = "{";
  json += "\"online\":true,";
  json += "\"seq\":"         + String(currentPacket.seq) + ",";
  json += "\"ageSec\":"      + String((millis() - lastReceiveMs) / 1000) + ",";
  json += "\"sleeping\":"    + boolText(currentPacket.sleeping) + ",";
  json += "\"secondsLeft\":" + String(currentPacket.secondsLeft) + ",";
  json += "\"distanceCm\":"  + String(currentPacket.distanceCm, 1) + ",";
  json += "\"temperatureC\":"+ String(currentPacket.temperatureC, 1) + ",";
  json += "\"humidityPct\":" + String(currentPacket.humidityPct, 1) + ",";
  json += "\"lightRaw\":"    + String(currentPacket.lightRaw) + ",";
  json += "\"motion\":"      + boolText(currentPacket.motion) + ",";
  json += "\"tilt\":"        + boolText(currentPacket.tilt) + ",";
  json += "\"dark\":"        + boolText(currentPacket.dark);
  json += "}";
  server.send(200, "application/json", json);
}

void appendBucketJson(String &json, HistoryBucket &b, String label) {
  json += "{\"label\":\"" + label + "\",";
  if (!b.valid || b.count == 0) {
    json += "\"distanceCm\":null,\"temperatureC\":null,\"humidityPct\":null,\"lightRaw\":null,\"motion\":null,\"tilt\":null,\"dark\":null";
  } else {
    json += "\"distanceCm\":"   + String(b.distanceCm, 1)  + ",";
    json += "\"temperatureC\":" + String(b.temperatureC, 1) + ",";
    json += "\"humidityPct\":"  + String(b.humidityPct, 1)  + ",";
    json += "\"lightRaw\":"     + String(b.lightRaw, 0)     + ",";
    json += "\"motion\":"       + boolText(b.motionCount > b.count / 2) + ",";
    json += "\"tilt\":"         + boolText(b.tiltCount   > b.count / 2) + ",";
    json += "\"dark\":"         + boolText(b.darkCount   > b.count / 2);
  }
  json += "}";
}

void sendHistoryJson(HistoryBucket buckets[], int bucketCount, unsigned long bucketMs, const char* unit) {
  uint32_t currentSlot = millis() / bucketMs;
  uint32_t firstSlot   = currentSlot >= (uint32_t)(bucketCount - 1)
                         ? currentSlot - (bucketCount - 1) : 0;
  String json;
  json.reserve(18000);
  json = "{\"points\":[";
  for (uint32_t slot = firstSlot; slot <= currentSlot; slot++) {
    if (slot > firstSlot) json += ",";
    int    index = slot % bucketCount;
    int    age   = currentSlot - slot;
    String label = age == 0 ? "jetzt" : "-" + String(age) + unit;
    if (buckets[index].valid && buckets[index].slot == slot) {
      appendBucketJson(json, buckets[index], label);
    } else {
      HistoryBucket empty = {};
      appendBucketJson(json, empty, label);
    }
  }
  json += "]}";
  server.send(200, "application/json", json);
}

void handleHistory() {
  String range = server.arg("range");
  if (range == "week") sendHistoryJson(weekHistory, WEEK_BUCKETS, WEEK_BUCKET_MS, "h");
  else                 sendHistoryJson(hourHistory,  HOUR_BUCKETS, HOUR_BUCKET_MS, "x5min");
}

// ================================================================
// SETUP
// ================================================================
void setup() {
  Serial.begin(115200);

  setupNetwork();

  if (esp_now_init() != ESP_OK) {
    Serial.println("ESP-NOW Fehler");
    while (true);
  }
  esp_now_register_recv_cb(onDataRecv);

  server.on("/",            handleRoot);
  server.on("/api/current", handleCurrent);
  server.on("/api/history", handleHistory);
  server.begin();
  Serial.println("Webserver gestartet");

  // Startnachricht an Telegram senden
  if (WiFi.status() == WL_CONNECTED) {
    sendTelegram("🟢 *ESP32 Receiver gestartet!*\nIP: " + WiFi.localIP().toString() +
                 "\nBefehle: /status /alerts /auto /help");
  }
}

// ================================================================
// LOOP
// ================================================================
void loop() {
  processPendingPacket();
  server.handleClient();
  handleTelegramCommands();  // Befehle empfangen
  handleTelegramAlerts();    // Alerts & Auto-Status senden
}
